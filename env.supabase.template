# 🚀 Go2Study Bot Configuration Template for Supabase

# 🤖 Telegram Bot Token
# Получить можно у @BotFather в Telegram
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here

# 🧠 Google Gemini API Key для ИИ-генерации вопросов
# Получить можно в Google AI Studio: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# 🗄️ Supabase PostgreSQL Database Configuration
# Включить использование PostgreSQL (true для продакшена, false для локальной SQLite)
USE_POSTGRESQL=true

# 🔗 Supabase Database Connection String (Transaction Pooler - РЕКОМЕНДУЕТСЯ)
# Transaction Pooler идеален для stateless приложений вроде Telegram ботов
# Формат: postgres://[WORD]@project-ref.pooler.supabase.com:6543/postgres
DATABASE_URL=postgres://[WORD]@project-ref.pooler.supabase.com:6543/postgres

# 🎛️ Alternative: Session Pooler (НЕ рекомендуется для нашего бота)
# Используйте только если Transaction Pooler не работает
# SUPABASE_SESSION_URL=postgresql://postgres.project:[PASSWORD]@aws-0-region.pooler.supabase.com:5432/postgres

# 📊 Logging Level (optional)
# Возможные значения: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO

# 🌍 Environment (optional)
# Возможные значения: development, production
ENVIRONMENT=production

# 📝 Application Name (optional)
# Используется для идентификации в логах подключений к БД
APP_NAME=go2study_bot_supabase 